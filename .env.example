# Leamsp API Environment Variables
# Copy this file to .dev.vars for local development

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars

# Brevo Email Service
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM=noreply@leamspoyostate.com

# Cloudinary (for image/video uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=leamsp
CLOUDINARY_FOLDER=leamsp

# Environment
ENVIRONMENT=development
DEV_MODE=true
