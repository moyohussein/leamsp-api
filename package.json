{
  "name": "leamsp-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:generate": "npx prisma generate",
    "db:migrate": "wrangler d1 migrations apply leamsp-db --local",
    "db:migrate:deploy": "wrangler d1 migrations apply leamsp-db",
    "db:studio": "wrangler d1 execute leamsp-db --command='.tables' --local",
    "db:reset": "wrangler d1 execute leamsp-db --command='DROP TABLE IF EXISTS _prisma_migrations;' --local && wrangler d1 migrations apply leamsp-db --local",
    "test:email-verification": "tsx scripts/test-email-verification.ts",
    "test:password-reset": "tsx scripts/test-password-reset.ts",
    "admin:create": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "@hono/zod-validator": "^0.7.2",
    "@prisma/adapter-d1": "^6.13.0",
    "@prisma/client": "^6.13.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt-ts": "^7.1.0",
    "date-fns": "^4.1.0",
    "hono": "^4.9.0",
    "jsonwebtoken": "^9.0.2",
    "lucia": "^3.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250810.0",
    "@types/node": "^24.2.1",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "tsx": "^4.20.3",
    "wrangler": "^4.28.1"
  }
}
